{
    "name": "enzolarosa/mqtt-broadcast",
    "description": "Use the mqtt power in your projects",
    "keywords": [
        "enzolarosa",
        "laravel",
        "mqtt-broadcast",
        "mqtt",
        "broadcast"
    ],
    "homepage": "https://github.com/enzolarosa/mqtt-broadcast",
    "license": "MIT",
    "authors": [
        {
            "name": "Vincenzo La Rosa",
            "email": "hello@enzolarosa.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4|^8.5",
        "ext-pcntl": "*",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "php-mqtt/client": "^2.0.0",
        "ext-posix": "*"
    },
    "require-dev": {
        "nunomaduro/collision": "^7.0|^8.0",
        "nunomaduro/larastan": "^2.0.1",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^1.0",
        "phpstan/phpstan-phpunit": "^1.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "enzolarosa\\MqttBroadcast\\": "src",
            "enzolarosa\\MqttBroadcast\\Database\\Factories\\": "database/factories"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "enzolarosa\\MqttBroadcast\\Tests\\": "tests",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "pint": "vendor/bin/pint",
        "serve": [
            "@publish-assets",
            "testbench serve --host=0.0.0.0 --port=8000"
        ],
        "publish-assets": "testbench vendor:publish --tag=mqtt-broadcast-assets --force",
        "db:seed": "testbench db:seed --class=Workbench\\\\Database\\\\Seeders\\\\DatabaseSeeder"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "enzolarosa\\MqttBroadcast\\MqttBroadcastServiceProvider"
            ],
            "aliases": {
                "MqttBroadcast": "enzolarosa\\MqttBroadcast\\Facades\\MqttBroadcast"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
